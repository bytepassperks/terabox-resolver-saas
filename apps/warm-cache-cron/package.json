{
  "name": "@trs/warm-cache-cron",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/cron.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/cron.ts",
    "start": "node dist/cron.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo \"no lint configured\"",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@trs/cache-layer": "workspace:*",
    "@trs/logger": "workspace:*",
    "@trs/metrics": "workspace:*",
    "@trs/resolver-core": "workspace:*",
    "@trs/shared-types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
