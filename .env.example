# ─────────────────────────────────────────────────────────────────────────────
# terabox-resolver-saas — environment template
# Copy to `.env` and fill in values. Never commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# ── Telegram bot cluster ─────────────────────────────────────────────────────
# Comma-separated list of bot tokens. The public-facing bot is the FIRST token;
# additional tokens are worker bots used by the router for load balancing.
TELEGRAM_BOT_TOKENS=123456:AAA,234567:BBB,345678:CCC
TELEGRAM_PUBLIC_BOT_USERNAME=teraresolvebot
# Webhook mode (recommended for production). Leave empty to use long polling.
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=
# Stars payment provider token is implicit for Stars (empty string); keep for future fiat.
TELEGRAM_STARS_PROVIDER_TOKEN=

# ── Resolver gateway ─────────────────────────────────────────────────────────
RESOLVER_API_URL=http://localhost:4001
RESOLVER_API_INTERNAL_TOKEN=change-me-internal-token
RESOLVER_PORT=4001
RESOLVER_TIMEOUT_MS=15000
RESOLVER_FAILURE_THRESHOLD=5
RESOLVER_RETRY_WINDOW_MS=60000

# ── Admin API ────────────────────────────────────────────────────────────────
ADMIN_API_PORT=4002
ADMIN_JWT_SECRET=change-me-admin-jwt-secret-32-bytes-min
ADMIN_JWT_ISSUER=terabox-resolver-saas
# Comma-separated Telegram user IDs that bootstrap into admin role.
ADMIN_BOOTSTRAP_TELEGRAM_IDS=

# ── Postgres ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/terabox_resolver
DATABASE_SSL=false
DATABASE_POOL_MAX=10

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=trs:

# ── Cache tuning ─────────────────────────────────────────────────────────────
CACHE_BASE_TTL_SECONDS=7200
CACHE_POPULARITY_MULTIPLIER_SECONDS=600
CACHE_MAX_TTL_SECONDS=86400
RESOLVE_LOCK_TTL_SECONDS=30

# ── Worker relay mesh (Cloudflare) ───────────────────────────────────────────
# Comma-separated relay URLs (geo-distributed). Router picks least-loaded.
WORKER_RELAY_URLS=https://relay-apac.example.workers.dev,https://relay-eu.example.workers.dev,https://relay-us.example.workers.dev
WORKER_RELAY_SECRET=change-me-hmac-secret-shared-with-worker
# signed-redirect | proxy-passthrough
RELAY_MODE=signed-redirect
RELAY_SIGNED_URL_TTL_SECONDS=900

# ── Rate limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_FREE_WINDOW_SECONDS=20
RATE_LIMIT_PAID_WINDOW_SECONDS=5
RATE_LIMIT_PREMIUM_WINDOW_SECONDS=2
RATE_LIMIT_IP_PER_MINUTE=60

# ── Credits / plans ──────────────────────────────────────────────────────────
FREE_DAILY_CREDITS=3
CREDIT_COST_PER_RESOLVE=1

# ── Observability ────────────────────────────────────────────────────────────
METRICS_ENABLED=true
METRICS_PORT=9090
